-- SISTEMA DE TROCAR DE ABAS
local function MudarAba(abaAtiva)
    AreaPrincipais.Visible = false
    AreaRaridades.Visible = false
    AreaINFO.Visible = false
    AreaSET.Visible = false

    AbaPrincipais.BackgroundColor3 = Color3.fromRGB(25,25,25)
    AbaPrincipais.TextColor3 = Color3.new(0.7,0.7,0.7)
    AbaRaridades.BackgroundColor3 = Color3.fromRGB(25,25,25)
    AbaRaridades.TextColor3 = Color3.new(0.7,0.7,0.7)
    AbaINFO.BackgroundColor3 = Color3.fromRGB(25,25,25)
    AbaINFO.TextColor3 = Color3.new(0.7,0.7,0.7)
    AbaSET.BackgroundColor3 = Color3.fromRGB(25,25,25)
    AbaSET.TextColor3 = Color3.new(0.7,0.7,0.7)

    if abaAtiva == "PRINCIPAIS" then
        AreaPrincipais.Visible = true
        AbaPrincipais.BackgroundColor3 = Color3.fromRGB(40,40,40)
        AbaPrincipais.TextColor3 = cores.letra[indiceCorLetra]
    elseif abaAtiva == "RARIDADES" then
        AreaRaridades.Visible = true
        AbaRaridades.BackgroundColor3 = Color3.fromRGB(40,40,40)
        AbaRaridades.TextColor3 = cores.letra[indiceCorLetra]
    elseif abaAtiva == "INFO" then
        AreaINFO.Visible = true
        AbaINFO.BackgroundColor3 = Color3.fromRGB(40,40,40)
        AbaINFO.TextColor3 = cores.letra[indiceCorLetra]
    elseif abaAtiva == "SET" then
        AreaSET.Visible = true
        AbaSET.BackgroundColor3 = Color3.fromRGB(40,40,40)
        AbaSET.TextColor3 = cores.letra[indiceCorLetra]
    end
end

-- Eventos das abas
AbaPrincipais.MouseButton1Click:Connect(function() MudarAba("PRINCIPAIS") end)
AbaRaridades.MouseButton1Click:Connect(function() MudarAba("RARIDADES") end)
AbaINFO.MouseButton1Click:Connect(function() MudarAba("INFO") end)
AbaSET.MouseButton1Click:Connect(function() MudarAba("SET") end)

