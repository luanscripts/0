-- MENU SEGUE O QUADRADO QUANDO MOVIDO
local ultimaPosQuadrado = QuadradoNome.Position
RunService.RenderStepped:Connect(function()
    if QuadradoNome.Position ~= ultimaPosQuadrado and not menuAberto then
        MainBorder.Position = UDim2.new(
            QuadradoNome.Position.X.Scale,
            QuadradoNome.Position.X.Offset,
            QuadradoNome.Position.Y.Scale,
            QuadradoNome.Position.Y.Offset + 50
        )
        ultimaPosQuadrado = QuadradoNome.Position
    end

    -- Manter velocidade ativada
    if velocidadeAtivada and Player.Character and Player.Character:FindFirstChild("Humanoid") then
        Player.Character.Humanoid.WalkSpeed = 50
    end
end)
