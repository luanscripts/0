-- FUNÇÃO CRIAR BOTÃO DE TP
local function CriarBotaoTP(nome, destino, area)
    local Btn = Instance.new("Frame")
    Btn.Parent = area
    Btn.Size = UDim2.new(1,0,0,30)
    Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)

    local Icone = Instance.new("TextLabel")
    Icone.Parent = Btn
    Icone.Size = UDim2.new(0,16,1,0)
    Icone.Position = UDim2.new(0,8,0,0)
    Icone.BackgroundTransparency = 1
    Icone.Text = "📍"
    Icone.TextSize = 12
    Icone.TextYAlignment = Enum.TextYAlignment.Center

    local Texto = Instance.new("TextLabel")
    Texto.Parent = Btn
    Texto.Size = UDim2.new(1, -28, 1, 0)
    Texto.Position = UDim2.new(0, 22, 0, 0)
    Texto.BackgroundTransparency = 1
    Texto.Text = nome
    Texto.TextColor3 = cores.letra[indiceCorLetra]
    Texto.Font = Enum.Font.GothamBold
    Texto.TextSize = 12
    Texto.TextYAlignment = Enum.TextYAlignment.Center
    Texto.TextXAlignment = Enum.TextXAlignment.Left

    local Click = Instance.new("TextButton")
    Click.Parent = Btn
    Click.Size = UDim2.new(1,0,1,0)
    Click.BackgroundTransparency = 1
    Click.Text = ""
    Click.MouseButton1Click:Connect(function()
        if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            Player.Character.HumanoidRootPart.CFrame = destino
        end
    end)
end

